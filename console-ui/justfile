# Console UI - Just Commands
#
# Local development and E2E testing for the Bulletin Chain console UI.
#
# Quick start:
#   just dev              - Start vite dev server
#   just test             - Run integration Playwright tests (chain must be running)
#   just test-e2e         - Full E2E: zombienet + Docker IPFS + integration tests
#
# Prerequisites for local dev:
#   polkadot, polkadot-omni-node, polkadot-prepare-worker, polkadot-execute-worker
#   must be in PATH. Run `../scripts/setup_parachain_prerequisites.sh` to set up.
#
# See `just --list` for all available recipes.

# Paths
root_dir       := justfile_directory() / ".."
examples_dir   := root_dir / "examples"

# ── Defaults ─────────────────────────────────────────────────────────

default: dev

# ── Local Development ────────────────────────────────────────────────

# Start parachain (zombienet) and vite dev server
dev runtime="bulletin-westend-runtime":
    #!/usr/bin/env bash
    set -e

    echo "🚀 Starting local dev environment (parachain)..."

    TEST_DIR="$(mktemp -d /tmp/bulletin-dev-XXXXX)/test"
    mkdir -p "$TEST_DIR"
    echo "   Test directory: $TEST_DIR"

    # Start parachain via zombienet (reuses examples justfile)
    just setup "$TEST_DIR" "{{ runtime }}"

    # Cleanup on exit
    trap "echo ''; echo '🛑 Stopping services...'; just teardown '$TEST_DIR'" EXIT INT TERM

    # Run vite dev server in foreground
    echo "   Starting vite dev server..."
    npm run dev

# ── Full Infra (reuses examples justfile) ────────────────────────────

# Helper to invoke examples justfile recipes
_examples *args:
    just --justfile {{ examples_dir }}/justfile --working-directory {{ examples_dir }} {{ args }}

# Setup zombienet + Docker IPFS + PAPI (full infra)
setup test_dir runtime="bulletin-westend-runtime":
    just _examples setup-services "{{ test_dir }}" "{{ runtime }}"

# Teardown zombienet + Docker IPFS
teardown test_dir:
    just _examples teardown-services "{{ test_dir }}"

# ── Testing ──────────────────────────────────────────────────────────

# Run integration Playwright tests (chain must already be running on ws://localhost:10000)
test: install ensure-browsers
    npx playwright test

# Full E2E lifecycle: setup → install → integration tests → teardown
test-e2e runtime="bulletin-westend-runtime":
    #!/usr/bin/env bash
    set -e

    TEST_DIR="$(just _examples compute-test-dir)"
    echo "📁 Test directory: $TEST_DIR"

    # Setup full infra (zombienet + Docker IPFS)
    echo ""
    echo "━━━ Setting up infrastructure ━━━"
    just setup "$TEST_DIR" "{{ runtime }}"

    # Install console-ui dependencies and Playwright browsers
    just install
    just ensure-browsers

    # Run integration tests
    echo ""
    echo "━━━ Running integration tests ━━━"
    set +e
    npx playwright test
    TEST_EXIT=$?
    set -e

    # Teardown
    echo ""
    echo "━━━ Tearing down infrastructure ━━━"
    just teardown "$TEST_DIR"

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    if [ $TEST_EXIT -eq 0 ]; then
        echo "✅ E2E tests passed!"
    else
        echo "❌ E2E tests failed with exit code $TEST_EXIT"
    fi
    exit $TEST_EXIT

# ── Helpers ──────────────────────────────────────────────────────────

# Install npm dependencies
install:
    npm install

# Install Playwright browsers (only if missing)
ensure-browsers:
    npx playwright install --with-deps chromium

# Generate PAPI descriptors from a running node
papi-generate ws_url="ws://localhost:10000":
    #!/usr/bin/env bash
    set -e
    echo "🔧 Generating PAPI descriptors from {{ ws_url }}..."
    npx papi add -w "{{ ws_url }}" bulletin
