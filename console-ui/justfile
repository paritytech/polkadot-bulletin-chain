# Console UI - Just Commands
#
# Local development and testing for the Bulletin Console UI.
#
# Quick start:
#   just dev              - Start vite dev server
#   just test             - Run integration Playwright tests (chain must be running)
#
# See `just --list` for all available recipes.


# ── Defaults ─────────────────────────────────────────────────────────

default: dev

# Collator-1 P2P multiaddrs (deterministic zombienet node keys; must match
# WESTEND_PEER1_* / PASEO_PEER1_* in examples/justfile)
WESTEND_COLLATOR_MULTIADDR := "/ip4/127.0.0.1/tcp/10001/ws/p2p/12D3KooWJKVVNYByvML4Pgx1GWAYryYo6exA68jQX9Mw3AJ6G5gQ"
PASEO_COLLATOR_MULTIADDR := "/ip4/127.0.0.1/tcp/10001/ws/p2p/12D3KooWKjTeRJH8nMcFytc7qTTCQy7JrFgiZFr7iUjd1aPEBn8v"

# ── Helpers ──────────────────────────────────────────────────────────

# Install npm dependencies
install:
    npm install

# Install Playwright browsers (only if missing)
ensure-browsers:
    npx playwright install --with-deps chromium

# ── Local Development ────────────────────────────────────────────────

# Start vite dev server
dev: 
    #!/usr/bin/env bash
    set -e

    # Run vite dev server in foreground
    echo "   Starting vite dev server..."
    npm run dev

# ── Testing ──────────────────────────────────────────────────────────

# Run integration Playwright tests (chain must already be running on ws://localhost:10000)
test runtime=env_var_or_default("RUNTIME_PACKAGE", "bulletin-westend-runtime"): install ensure-browsers
    npx papi generate
    COLLATOR_MULTIADDR={{ if runtime == "bulletin-paseo-runtime" { PASEO_COLLATOR_MULTIADDR } else { WESTEND_COLLATOR_MULTIADDR } }} npx playwright test
