# Generated by Cargo
# will have compiled files and executables
**/target/
# These are backup files generated by rustfmt
**/*.rs.bk

# Cached polkadot-sdk / try-runtime / zombienet binaries fetched or built by
# scripts/get_polkadot_binaries.sh
/.polkadot-binaries/

# OS
.DS_Store
Thumbs.db

# Editor swap files
*.swp
*.swo
*~

# Environment files
.env
.env.local
.env.*.local
.envrc
.direnv

# IDE
.idea
.vscode

# Node.js
**/node_modules/
tsconfig.tsbuildinfo

# Python
__pycache__

# Polkadot API generated files (descriptors dir is gitignored inside .papi)

# Local test files
kubo/

# Stress test outputs
stress-test/results/
stress-test/hop-results.png

# `zombienet-*` (a downloaded binary) lives at the repo root; scoping the glob to `/`
# prevents it from sweeping in unrelated files like `.github/workflows/zombienet-*.yml`.
/zombienet-*
!/zombienet-sdk-tests/

# Coverage reports
coverage/

# Build outputs
**/dist/
console-ui/.vite/
console-ui/tsconfig.tsbuildinfo

# mdBook build output
console-ui/public/docs/
console-ui/public/sdk-docs/
docs/book/book/

# Playwright
console-ui/test-results/
console-ui/playwright-report/
console-ui/blob-report/
console-ui/playwright/.cache/

# Specs for zombienet (need to be fresh)
zombienet/bulletin-westend-spec.json
zombienet/bulletin-paseo-spec.json
zombienet/bulletin-polkadot-spec.json
