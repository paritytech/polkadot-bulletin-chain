{
  "title": "Bulletin IPFS Gateway (kubo)",
  "uid": "bulletin-ipfs-gateway",
  "tags": ["bulletin", "ipfs", "kubo", "gateway"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(ipfs_http_gw_responses_total, namespace)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(ipfs_http_gw_responses_total{namespace=~\"$namespace\"}, pod)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Gateway health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "5xx ratio (15m)",
      "description": "Fraction of gateway responses that are 5xx over 15m. The BulletinIpfsGateway5xx alert fires at >0.05 per-pod 5xx rate.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(ipfs_http_gw_responses_total{namespace=~\"$namespace\", pod=~\"$pod\", code=~\"5..\"}[15m])) / clamp_min(sum(rate(ipfs_http_gw_responses_total{namespace=~\"$namespace\", pod=~\"$pod\"}[15m])), 0.0001)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Request rate (rps)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(ipfs_http_gw_responses_total{namespace=~\"$namespace\", pod=~\"$pod\"}[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx rate by pod (alert signal)",
      "description": "Mirrors the BulletinIpfsGateway5xx alert: sum by (pod) rate of 5xx. Threshold line at 0.05.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.05 } ] },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (pod) (rate(ipfs_http_gw_responses_total{namespace=~\"$namespace\", pod=~\"$pod\", code=~\"5..\"}[5m]))",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Responses by status class",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (code) (rate(ipfs_http_gw_responses_total{namespace=~\"$namespace\", pod=~\"$pod\"}[5m]))",
          "legendFormat": "{{code}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Gateway latency (p50 / p90 / p99)",
      "description": "Verify metric name against /debug/metrics/prometheus; boxo exposes ipfs_http_gw_request_duration_seconds.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(ipfs_http_gw_request_duration_seconds_bucket{namespace=~\"$namespace\", pod=~\"$pod\"}[5m])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.90, sum by (le) (rate(ipfs_http_gw_request_duration_seconds_bucket{namespace=~\"$namespace\", pod=~\"$pod\"}[5m])))", "legendFormat": "p90" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(ipfs_http_gw_request_duration_seconds_bucket{namespace=~\"$namespace\", pod=~\"$pod\"}[5m])))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "row",
      "title": "Bitswap (verify metric names against the live endpoint)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 }
    },
    {
      "type": "timeseries",
      "title": "Bitswap blocks received / sent",
      "description": "Metric names to confirm: ipfs_bitswap_blocks_received / ipfs_bitswap_blocks_sent.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(ipfs_bitswap_blocks_received{namespace=~\"$namespace\", pod=~\"$pod\"}[5m]))", "legendFormat": "received" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(ipfs_bitswap_blocks_sent{namespace=~\"$namespace\", pod=~\"$pod\"}[5m]))", "legendFormat": "sent" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Bitswap data rate",
      "description": "Metric names to confirm: ipfs_bitswap_sent_all_blocks_bytes / ipfs_bitswap_recv_all_blocks_bytes.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(ipfs_bitswap_recv_all_blocks_bytes{namespace=~\"$namespace\", pod=~\"$pod\"}[5m]))", "legendFormat": "recv" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(ipfs_bitswap_sent_all_blocks_bytes{namespace=~\"$namespace\", pod=~\"$pod\"}[5m]))", "legendFormat": "sent" }
      ]
    },
    {
      "type": "row",
      "title": "Node health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }
    },
    {
      "type": "timeseries",
      "title": "Connected peers",
      "description": "Metric name to confirm (e.g. ipfs_p2p_peers_total).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (pod) (ipfs_p2p_peers_total{namespace=~\"$namespace\", pod=~\"$pod\"})", "legendFormat": "{{pod}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Process memory (RSS)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "process_resident_memory_bytes{namespace=~\"$namespace\", pod=~\"$pod\"}", "legendFormat": "{{pod}}" }
      ]
    }
  ]
}
