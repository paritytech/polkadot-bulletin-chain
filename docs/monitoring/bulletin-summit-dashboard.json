{
  "title": "Bulletin Summit",
  "uid": "bulletin-summit",
  "tags": [
    "bulletin",
    "summit",
    "w3s"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "chain",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(substrate_block_height{chain=~\"bulletin-summit\"}, chain)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Chain liveness",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Block production rate (blocks/min)",
      "description": "Drops to 0 = stall (the BulletinBlockProductionStall alert).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0.1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (chain) (rate(substrate_block_height{chain=~\"$chain\", status=\"best\"}[5m])) * 60",
          "legendFormat": "{{chain}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Finality lag (best - finalized)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (chain) (substrate_block_height{chain=~\"$chain\", status=\"best\"} - ignoring(status) substrate_block_height{chain=~\"$chain\", status=\"finalized\"})",
          "legendFormat": "{{chain}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Best block height",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (chain) (substrate_block_height{chain=~\"$chain\", status=\"best\"})",
          "legendFormat": "{{chain}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      }
    },
    {
      "type": "timeseries",
      "title": "Finalized block height",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (chain) (substrate_block_height{chain=~\"$chain\", status=\"finalized\"})",
          "legendFormat": "{{chain}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      }
    },
    {
      "type": "timeseries",
      "title": "Peers",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (chain, node) (substrate_sub_libp2p_peers_count{chain=~\"$chain\"})",
          "legendFormat": "{{node}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "IPFS gateway (kubo)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      }
    },
    {
      "type": "stat",
      "title": "Gateway 5xx ratio (15m)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 0,
        "y": 26
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(ipfs_http_gw_responses_total{job=~\"ipfs-summit-kubo\", code=~\"5..\"}[15m])) / clamp_min(sum(rate(ipfs_http_gw_responses_total{job=~\"ipfs-summit-kubo\"}[15m])), 0.0001)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Gateway responses by status class",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 7,
        "w": 18,
        "x": 6,
        "y": 26
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (code) (increase(ipfs_http_gw_responses_total{job=~\"ipfs-summit-kubo\"}[$__rate_interval]))",
          "legendFormat": "{{code}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Bitswap",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 33
      }
    },
    {
      "type": "timeseries",
      "title": "Bitswap dont_have ratio",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 34
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (chain, node) (rate(substrate_sub_libp2p_bitswap_entries_total{outcome=\"dont_have\", chain=~\"$chain\"}[5m])) / clamp_min(sum by (chain, node) (rate(substrate_sub_libp2p_bitswap_entries_total{chain=~\"$chain\"}[5m])), 1e-9)",
          "legendFormat": "{{node}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Bitswap inbound request p95 latency",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 34
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.95, sum by (le, chain, node) (rate(substrate_sub_libp2p_bitswap_inbound_request_duration_seconds_bucket{chain=~\"$chain\"}[5m])))",
          "legendFormat": "{{node}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "HOP RPC (substrate_rpc_calls_*)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 42
      }
    },
    {
      "type": "timeseries",
      "title": "HOP calls by node/method",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 43
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (method, node) (increase(substrate_rpc_calls_started{chain=~\"$chain\", method=~\"hop_.*\", method!=\"hop_poolStatus\", node!~\".*rpc.*\"}[$__rate_interval]))",
          "legendFormat": "{{node}} {{method}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "HOP calls total (range)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 43
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (method, node) (increase(substrate_rpc_calls_started{chain=~\"$chain\", method=~\"hop_.*\", method!=\"hop_poolStatus\", node!~\".*rpc.*\"}[$__range]))",
          "legendFormat": "{{node}} {{method}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HOP call errors by node/method",
      "description": "is_error=true completions per node.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 43
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (method, node) (increase(substrate_rpc_calls_finished{chain=~\"$chain\", method=~\"hop_.*\", method!=\"hop_poolStatus\", node!~\".*rpc.*\", is_error=\"true\"}[$__rate_interval]))",
          "legendFormat": "{{node}} {{method}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HOP call p95 latency by node/method",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 51
      },
      "fieldConfig": {
        "defaults": {
          "unit": "\u00b5s"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.95, sum by (le, method, node) (rate(substrate_rpc_calls_time_bucket{chain=~\"$chain\", method=~\"hop_.*\", method!=\"hop_poolStatus\", node!~\".*rpc.*\"}[5m])))",
          "legendFormat": "{{node}} {{method}}"
        }
      ]
    }
  ]
}