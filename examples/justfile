default: (run-authorize-and-store "bulletin-westend-runtime" "ws")

compute-test-dir:
    #!/usr/bin/env bash
    if [ -n "$TEST_DIR" ]; then
        echo "$TEST_DIR";
    else
        TEST_DIR="$(mktemp -d /tmp/bulletin-tests-run-XXXXX)/test";
        mkdir -p "$TEST_DIR";
        echo "$TEST_DIR";
    fi

# Install JavaScript dependencies
npm-install:
    npm install

kill-pids test_dir:
    #!/usr/bin/env bash
    set -e

    # Kill any existing background processes using stored PIDs
    echo "🔍 Checking for existing background processes - PIDs stored in {{ test_dir }}..."
    for pidfile in {{ test_dir }}/*.pid; do
        if [ -f "$pidfile" ]; then
            PID=$(cat "$pidfile")
            SERVICE=$(basename "$pidfile" .pid)
            if kill -0 $PID 2>/dev/null; then
                echo "   Found existing $SERVICE process (PID: $PID), pidfile: $pidfile"
                # Kill the process and its children
                pkill -TERM -P $PID 2>/dev/null || true
                sleep 2
                pkill -9 -P $PID 2>/dev/null || true
                sleep 2
                kill -9 $PID 2>/dev/null || true
                echo "   ✓ Cleaned up $SERVICE process"
            else
                echo "   Stale $SERVICE PID file: $pidfile found (process not running)"
            fi
            rm "$pidfile"
        fi
    done

# Wait for an RPC endpoint to accept connections, checking that the background process stays alive.
# Parameters:
#   pid - PID of the background process to monitor
#   log_file - Log file to tail on failure
#   port - TCP port to check (default: 10000)
#   timeout - Seconds to wait (default: 30)
_wait-for-rpc pid log_file port="10000" timeout="30":
    #!/usr/bin/env bash
    set -e
    echo "   Waiting for RPC on 127.0.0.1:{{ port }}..."
    for i in $(seq 1 {{ timeout }}); do
        if ! kill -0 {{ pid }} 2>/dev/null; then
            echo "   ❌ Process (PID {{ pid }}) died during startup. Logs:"
            tail -20 "{{ log_file }}"
            exit 1
        fi
        if (echo > /dev/tcp/127.0.0.1/{{ port }}) 2>/dev/null; then
            echo "   ✅ RPC is reachable (after ${i}s)"
            exit 0
        fi
        if [ "$i" -eq {{ timeout }} ]; then
            echo "   ❌ RPC not reachable after {{ timeout }} seconds"
            echo "   Debug: ss -tlnp | grep {{ port }}:"
            ss -tlnp 2>/dev/null | grep {{ port }} || netstat -tlnp 2>/dev/null | grep {{ port }} || true
            tail -20 "{{ log_file }}"
            exit 1
        fi
        sleep 1
    done

# Start a bulletin parachain (westend or paseo) with zombienet in background.
# Parameters:
#   runtime - Runtime name (e.g., "bulletin-westend-runtime" or "bulletin-paseo-runtime"),
#             taken from ../scripts/runtimes-matrix.json
bulletin-parachain-zombienet-start test_dir runtime="bulletin-westend-runtime":
    #!/usr/bin/env bash
    set -e

    ROOT_DIR="{{ justfile_directory() }}/.."
    POLKADOT_BIN_DIR="$(cd "$ROOT_DIR" && just binaries-polkadot)"
    ZOMBIENET_BIN_DIR="$(cd "$ROOT_DIR" && just binaries-zombienet)"
    POLKADOT_BINARY_PATH="$POLKADOT_BIN_DIR/polkadot"
    POLKADOT_PARACHAIN_BINARY_PATH="$POLKADOT_BIN_DIR/polkadot-omni-node"
    ZOMBIENET_BIN="$ZOMBIENET_BIN_DIR/zombienet"

    # Pick spec script + zombienet TOML based on the runtime
    if [ "{{ runtime }}" = "bulletin-westend-runtime" ]; then
        SPEC_SCRIPT="create_bulletin_westend_spec.sh"
        ZOMBIENET_TOML="zombienet/bulletin-westend-local.toml"
    elif [ "{{ runtime }}" = "bulletin-paseo-runtime" ]; then
        SPEC_SCRIPT="create_bulletin_paseo_spec.sh"
        ZOMBIENET_TOML="zombienet/bulletin-paseo-local.toml"
    else
        echo "❌ Unhandled runtime: {{ runtime }}"
        exit 1
    fi

    echo "   Creating chain spec for {{ runtime }}..."
    CSB_DIR="$(cd "$ROOT_DIR" && just binaries-chain-spec-builder)"
    PATH="$CSB_DIR:$PATH" "$ROOT_DIR/scripts/$SPEC_SCRIPT"

    cat <<EOF
    ⚡ Starting Bulletin chain with zombienet
        runtime   : {{ runtime }}
        test_dir  : {{ test_dir }}
        zombienet : $ZOMBIENET_BIN
        zombienet toml : $ZOMBIENET_TOML
        POLKADOT_BINARY_PATH : $POLKADOT_BINARY_PATH
        POLKADOT_PARACHAIN_BINARY_PATH : $POLKADOT_PARACHAIN_BINARY_PATH
    EOF
    # Zombienet resolves chain_spec_path relative to CWD, so run from repo root
    (cd "$ROOT_DIR" && yes y | POLKADOT_BINARY_PATH=$POLKADOT_BINARY_PATH \
        POLKADOT_PARACHAIN_BINARY_PATH=$POLKADOT_PARACHAIN_BINARY_PATH \
        $ZOMBIENET_BIN -p native spawn --dir {{ test_dir }} "$ROOT_DIR/$ZOMBIENET_TOML" > {{ test_dir }}/zombienet.log 2>&1) &

    ZOMBIENET_PID=$!
    echo $ZOMBIENET_PID > {{ test_dir }}/zombienet.pid
    echo "   Zombienet PID: $ZOMBIENET_PID"
    echo "   Log: {{ test_dir }}/zombienet.log"
    just _wait-for-rpc $ZOMBIENET_PID "{{ test_dir }}/zombienet.log"

# Check if Docker is available and running
_check-docker:
    #!/usr/bin/env bash
    if ! command -v docker &> /dev/null; then
        echo "❌ Error: Docker is not installed."
        echo "   Please install Docker Desktop from: https://www.docker.com/products/docker-desktop"
        exit 1
    fi

    if ! docker ps &> /dev/null; then
        echo "❌ Error: Docker is not running."
        echo "   Please start Docker Desktop and try again."
        echo "   On macOS: Open Docker Desktop from Applications"
        exit 1
    fi

