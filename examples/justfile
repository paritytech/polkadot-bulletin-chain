PREVIEWNET_HOP_RPC      := "wss://TODO-previewnet-bulletin-collator.polkadot.io"

# Network-specific IPFS gateways. TODO(#580): fill in once published.
WESTEND_IPFS_GATEWAY        := "http://TODO-westend-bulletin-ipfs"
PASEO_IPFS_GATEWAY          := "http://TODO-paseo-bulletin-ipfs"
