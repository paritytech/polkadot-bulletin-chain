# Internal: run all four canonical live tests against the given endpoints.
_run-live-tests rpc_url collator_url ipfs_gateway relay_spec parachain_spec seed image_size="small": npm-install
    #!/usr/bin/env bash
    set -e
    echo "🌐 Running live tests"
    echo "   RPC:           {{ rpc_url }}"
    echo "   HOP collator:  {{ collator_url }}"
    echo "   IPFS gateway:  {{ ipfs_gateway }}"
    echo "   Relay spec:    {{ relay_spec }}"
    echo "   Parachain spec:{{ parachain_spec }}"
    just papi-generate "{{ rpc_url }}"

    # Run every script even if an earlier one fails, so one blocked endpoint
    # doesn't mask the rest. Collect failures and exit non-zero if any failed.
    set +e
    failed=""

    echo "▶️  store_big_data.js"
    node store_big_data.js "{{ rpc_url }}" "{{ seed }}" "{{ ipfs_gateway }}" "{{ image_size }}" || failed="$failed store_big_data.js"

    echo "▶️  authorize_and_store_papi_smoldot.js"
    # Parachain mode: relay spec is arg 1, bulletin parachain spec is arg 2.
    node authorize_and_store_papi_smoldot.js "{{ relay_spec }}" "{{ parachain_spec }}" "{{ ipfs_gateway }}" "{{ seed }}" || failed="$failed authorize_and_store_papi_smoldot.js"

    echo "▶️  hop_round_trip.js"
    # Chain/state ops go to rpc_url; the HOP pool is node-local, so the pool
    # round-trip is pinned to a single node (collator_url). They coincide for a
    # single-node deployment (collator_url defaults to rpc_url when left blank).
    node hop_round_trip.js "{{ rpc_url }}" "{{ seed }}" "{{ ipfs_gateway }}" "{{ collator_url }}" || failed="$failed hop_round_trip.js"

    echo "▶️  check_chopsticks.js"
    node check_chopsticks.js "{{ rpc_url }}" || failed="$failed check_chopsticks.js"

    if [ -n "$failed" ]; then
        echo "❌ Failed live tests:$failed"
        exit 1
    fi
    echo "✅ All live tests passed"

# Run live tests against Westend Bulletin
