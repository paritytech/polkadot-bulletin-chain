# Download and install Kubo IPFS binary
ipfs-kubo-install:
    #!/usr/bin/env bash
    set -e
    KUBO_DIR="{{ KUBO_DIR }}"
    if [ -x "$KUBO_DIR/ipfs" ]; then
        echo "   Kubo already installed at $KUBO_DIR/ipfs"
        "$KUBO_DIR/ipfs" --version
        exit 0
    fi
    echo "📦 Installing Kubo {{ KUBO_VERSION }}..."
    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64) ARCH="amd64" ;;
        aarch64|arm64) ARCH="arm64" ;;
        *) echo "❌ Unsupported architecture: $ARCH"; exit 1 ;;
    esac
    OS=$(uname -s | tr '[:upper:]' '[:lower:]')
    TARBALL="kubo_{{ KUBO_VERSION }}_${OS}-${ARCH}.tar.gz"
    URL="https://dist.ipfs.tech/kubo/{{ KUBO_VERSION }}/${TARBALL}"
    echo "   Downloading $URL..."
    mkdir -p "$KUBO_DIR"
    curl -fsSL "$URL" | tar xz -C "$KUBO_DIR" --strip-components=1 kubo/ipfs
    chmod +x "$KUBO_DIR/ipfs"
    "$KUBO_DIR/ipfs" --version
    echo "   ✓ Kubo installed at $KUBO_DIR/ipfs"

# Start IPFS Kubo daemon locally (no Docker required)
# Peering.Peers is configured before daemon start so Kubo auto-connects to chain nodes.
ipfs-kubo-start test_dir runtime: ipfs-kubo-install
    #!/usr/bin/env bash
    set -e
    echo "🔧 Starting IPFS Kubo daemon (local mode)..."

    KUBO_DIR="{{ KUBO_DIR }}"
    IPFS_CMD="$KUBO_DIR/ipfs"
    export IPFS_PATH="{{ test_dir }}/ipfs-repo"

    IPFS_SWARM_PORT={{ IPFS_SWARM_PORT }}
    IPFS_API_PORT={{ IPFS_API_PORT }}
    IPFS_GATEWAY_PORT={{ IPFS_GATEWAY_PORT }}

    # Initialize fresh IPFS repo
    rm -rf "$IPFS_PATH"
    $IPFS_CMD init --profile server

    # Configure isolated mode
    $IPFS_CMD bootstrap rm --all
    $IPFS_CMD config --json Routing.Type '"none"'
    $IPFS_CMD config --json Discovery.MDNS.Enabled false
    $IPFS_CMD config --json Swarm.RelayClient.Enabled false
    $IPFS_CMD config --json Swarm.RelayService.Enabled false

    # Configure custom ports
    echo "   Configuring ports (swarm: ${IPFS_SWARM_PORT}, api: ${IPFS_API_PORT}, gateway: ${IPFS_GATEWAY_PORT})..."
    $IPFS_CMD config --json Addresses.Swarm "[\"/ip4/0.0.0.0/tcp/${IPFS_SWARM_PORT}\", \"/ip6/::/tcp/${IPFS_SWARM_PORT}\"]"
    $IPFS_CMD config Addresses.API "/ip4/0.0.0.0/tcp/${IPFS_API_PORT}"
    $IPFS_CMD config Addresses.Gateway "/ip4/0.0.0.0/tcp/${IPFS_GATEWAY_PORT}"

    # Configure Peering.Peers so Kubo automatically connects and reconnects to chain nodes
    echo "   Configuring Peering.Peers for {{ runtime }}..."
    if [ "{{ runtime }}" = "bulletin-westend-runtime" ]; then
        PEERS='[{"ID":"{{ WESTEND_PEER1_ID }}","Addrs":["/ip4/127.0.0.1/tcp/{{ WESTEND_PEER1_PORT }}/ws"]},{"ID":"{{ WESTEND_PEER2_ID }}","Addrs":["/ip4/127.0.0.1/tcp/{{ WESTEND_PEER2_PORT }}/ws"]}]'
    elif [ "{{ runtime }}" = "bulletin-polkadot-parachain-runtime" ]; then
        PEERS='[{"ID":"{{ POLKADOT_PARACHAIN_PEER1_ID }}","Addrs":["/ip4/127.0.0.1/tcp/{{ POLKADOT_PARACHAIN_PEER1_PORT }}/ws"]},{"ID":"{{ POLKADOT_PARACHAIN_PEER2_ID }}","Addrs":["/ip4/127.0.0.1/tcp/{{ POLKADOT_PARACHAIN_PEER2_PORT }}/ws"]}]'
    elif [ "{{ runtime }}" = "bulletin-polkadot-runtime" ]; then
        PEERS='[{"ID":"{{ POLKADOT_PEER1_ID }}","Addrs":["/ip4/127.0.0.1/tcp/{{ POLKADOT_PEER1_PORT }}/ws"]},{"ID":"{{ POLKADOT_PEER2_ID }}","Addrs":["/ip4/127.0.0.1/tcp/{{ POLKADOT_PEER2_PORT }}/ws"]}]'
    else
        echo "❌ Unhandled runtime: {{ runtime }}"
        exit 1
    fi
    $IPFS_CMD config --json Peering.Peers "$PEERS"

    # Start daemon in background
    $IPFS_CMD daemon > {{ test_dir }}/ipfs-node.log 2>&1 &
    IPFS_PID=$!
    echo $IPFS_PID > {{ test_dir }}/ipfs-kubo.pid

    # Wait for daemon to be ready
    CUSTOM_API="--api /ip4/127.0.0.1/tcp/${IPFS_API_PORT}"
    echo "   Waiting for IPFS daemon API to be ready on port ${IPFS_API_PORT}..."
    for i in $(seq 1 30); do
        if $IPFS_CMD $CUSTOM_API id >/dev/null 2>&1; then
            echo "   IPFS API is ready (PID: $IPFS_PID)"
            break
        fi
        if [ "$i" -eq 30 ]; then
            echo "   ❌ IPFS API failed to start within 30 seconds"
            cat {{ test_dir }}/ipfs-node.log
            exit 1
        fi
        sleep 1
    done

    $IPFS_CMD --version

    # Enable Bitswap debug logging
    $IPFS_CMD $CUSTOM_API log level bitswap debug
    $IPFS_CMD $CUSTOM_API log level bitswap/client debug

    echo "   Log: {{ test_dir }}/ipfs-node.log"

# Shutdown local Kubo IPFS daemon
ipfs-kubo-shutdown test_dir:
    #!/usr/bin/env bash
    echo "🛑 Shutting down IPFS Kubo daemon..."
    if [ -f "{{ test_dir }}/ipfs-kubo.pid" ]; then
        PID=$(cat "{{ test_dir }}/ipfs-kubo.pid")
        if kill -0 $PID 2>/dev/null; then
            kill $PID 2>/dev/null || true
            # Wait up to 2s for graceful shutdown before force-killing
            for _ in $(seq 1 20); do
                kill -0 $PID 2>/dev/null || break
                sleep 0.1
            done
            kill -9 $PID 2>/dev/null || true
            echo "   ✓ Kubo daemon stopped (PID: $PID)"
        else
            echo "   ⚠ Kubo daemon not running (stale PID: $PID)"
        fi
        rm -f "{{ test_dir }}/ipfs-kubo.pid"
    else
        echo "   ⚠ No Kubo PID file found"
    fi
    rm -rf "{{ test_dir }}/ipfs-repo" 2>/dev/null || true

# ============================================================================

# Start IPFS Docker container
# Peering.Peers is configured before daemon restart so Kubo auto-connects to chain nodes.
ipfs-start test_dir runtime: _check-docker
    #!/usr/bin/env bash
    set -e
    echo "🐳 Starting IPFS Docker container..."

    IPFS_SWARM_PORT={{ IPFS_SWARM_PORT }}
    IPFS_API_PORT={{ IPFS_API_PORT }}
    IPFS_GATEWAY_PORT={{ IPFS_GATEWAY_PORT }}

    # Pull kubo image if not already present
    docker image inspect ipfs/kubo:latest >/dev/null 2>&1 || docker pull ipfs/kubo:latest

    # Remove old volume to start fresh (no cached peers)
    docker volume rm ipfs-data 2>/dev/null || true

    # Networking: use --network=host on Linux so the container can reach chain nodes
    # bound on 127.0.0.1 directly. On macOS, Docker Desktop tunnels host.docker.internal
    # through its VM to the host loopback, so bridge networking with port mapping works.
    if [[ "$(uname)" == "Linux" ]]; then
        NETWORK_ARGS="--network=host"
        # With host networking the container shares the host's loopback,
        # so chain nodes on 127.0.0.1 are reachable directly.
        PEER_ADDR="/ip4/127.0.0.1"
    else
        NETWORK_ARGS="-p 127.0.0.1:${IPFS_SWARM_PORT}:${IPFS_SWARM_PORT} -p 127.0.0.1:${IPFS_GATEWAY_PORT}:${IPFS_GATEWAY_PORT} -p 127.0.0.1:${IPFS_API_PORT}:${IPFS_API_PORT} --add-host=host.docker.internal:host-gateway"
        PEER_ADDR="/dns4/host.docker.internal"
    fi

    # Start container - daemon will init and start
    docker run -d --name ipfs-node -v ipfs-data:/data/ipfs $NETWORK_ARGS ipfs/kubo:latest
    echo "   Container: ipfs-node (network: $NETWORK_ARGS)"

    # Wait for the IPFS daemon API (default port 5001) to be ready
    DEFAULT_API="--api /ip4/127.0.0.1/tcp/5001"
    echo "   Waiting for IPFS daemon API to be ready..."
    for i in $(seq 1 30); do
        if docker exec ipfs-node ipfs $DEFAULT_API id >/dev/null 2>&1; then
            echo "   IPFS API is ready"
            break
        fi
        if [ "$i" -eq 30 ]; then
            echo "   ❌ IPFS API failed to start within 30 seconds"
            exit 1
        fi
        sleep 1
    done

    # Configure IPFS for isolated mode via the running daemon's API (avoids repo.lock contention)
    echo "   Configuring isolated mode..."
    docker exec ipfs-node ipfs $DEFAULT_API bootstrap rm --all
    docker exec ipfs-node ipfs $DEFAULT_API config --json Routing.Type '"none"'
    docker exec ipfs-node ipfs $DEFAULT_API config --json Discovery.MDNS.Enabled false
    docker exec ipfs-node ipfs $DEFAULT_API config --json Swarm.RelayClient.Enabled false
    docker exec ipfs-node ipfs $DEFAULT_API config --json Swarm.RelayService.Enabled false

    # Configure custom ports to avoid conflicts with other IPFS instances
    echo "   Configuring custom ports (swarm: ${IPFS_SWARM_PORT}, api: ${IPFS_API_PORT}, gateway: ${IPFS_GATEWAY_PORT})..."
    docker exec ipfs-node ipfs $DEFAULT_API config --json Addresses.Swarm "[\"/ip4/0.0.0.0/tcp/${IPFS_SWARM_PORT}\", \"/ip6/::/tcp/${IPFS_SWARM_PORT}\"]"
    docker exec ipfs-node ipfs $DEFAULT_API config Addresses.API "/ip4/0.0.0.0/tcp/${IPFS_API_PORT}"
    docker exec ipfs-node ipfs $DEFAULT_API config Addresses.Gateway "/ip4/0.0.0.0/tcp/${IPFS_GATEWAY_PORT}"

    # Configure Peering.Peers so Kubo automatically connects and reconnects to chain nodes
    # (set before restart so the daemon picks up the config on boot)
    echo "   Configuring Peering.Peers for {{ runtime }}..."
    if [ "{{ runtime }}" = "bulletin-westend-runtime" ]; then
        PEERS="[{\"ID\":\"{{ WESTEND_PEER1_ID }}\",\"Addrs\":[\"${PEER_ADDR}/tcp/{{ WESTEND_PEER1_PORT }}/ws\"]},{\"ID\":\"{{ WESTEND_PEER2_ID }}\",\"Addrs\":[\"${PEER_ADDR}/tcp/{{ WESTEND_PEER2_PORT }}/ws\"]}]"
    elif [ "{{ runtime }}" = "bulletin-polkadot-parachain-runtime" ]; then
        PEERS="[{\"ID\":\"{{ POLKADOT_PARACHAIN_PEER1_ID }}\",\"Addrs\":[\"${PEER_ADDR}/tcp/{{ POLKADOT_PARACHAIN_PEER1_PORT }}/ws\"]},{\"ID\":\"{{ POLKADOT_PARACHAIN_PEER2_ID }}\",\"Addrs\":[\"${PEER_ADDR}/tcp/{{ POLKADOT_PARACHAIN_PEER2_PORT }}/ws\"]}]"
    elif [ "{{ runtime }}" = "bulletin-polkadot-runtime" ]; then
        PEERS="[{\"ID\":\"{{ POLKADOT_PEER1_ID }}\",\"Addrs\":[\"${PEER_ADDR}/tcp/{{ POLKADOT_PEER1_PORT }}/ws\"]},{\"ID\":\"{{ POLKADOT_PEER2_ID }}\",\"Addrs\":[\"${PEER_ADDR}/tcp/{{ POLKADOT_PEER2_PORT }}/ws\"]}]"
    else
        echo "❌ Unhandled runtime: {{ runtime }}"
        exit 1
    fi
    docker exec ipfs-node ipfs $DEFAULT_API config --json Peering.Peers "$PEERS"

    # Restart container to apply config changes (ports + peering, API now on custom port)
    echo "   Restarting daemon with isolated config..."
    docker restart ipfs-node

    CUSTOM_API="--api /ip4/127.0.0.1/tcp/${IPFS_API_PORT}"
    echo "   Waiting for IPFS daemon API to be ready on port ${IPFS_API_PORT}..."
    for i in $(seq 1 30); do
        if docker exec ipfs-node ipfs $CUSTOM_API id >/dev/null 2>&1; then
            echo "   IPFS API is ready"
            break
        fi
        if [ "$i" -eq 30 ]; then
            echo "   ❌ IPFS API failed to start within 30 seconds after restart"
            exit 1
        fi
        sleep 1
    done

    docker exec ipfs-node ipfs --version

    # Bitswap logging
    docker logs -f ipfs-node > {{ test_dir }}/ipfs-node.log 2>&1 &
    docker exec ipfs-node ipfs $CUSTOM_API log level bitswap debug
    docker exec ipfs-node ipfs $CUSTOM_API log level bitswap/client debug

    # Store container name in PID directory for cleanup
    echo "ipfs-node" > {{ test_dir }}/ipfs-docker.container

# Shutdown IPFS Docker container
ipfs-shutdown test_dir:
    #!/usr/bin/env bash
    
    echo "🛑 Shutting down IPFS Docker container..."
    docker stop ipfs-node 2>/dev/null || echo "   ⚠ Container not running or already stopped"
    docker rm ipfs-node 2>/dev/null || echo "   ⚠ Container not found or already removed"
    docker volume rm ipfs-data 2>/dev/null || echo "   ⚠ Volume not found or already removed"
    
    # Clean up container file if it exists
    [ -f "{{ test_dir }}/ipfs-docker.container" ] && rm "{{ test_dir }}/ipfs-docker.container" && echo "   ✓ Cleaned up container file" || true

# Generate PAPI descriptors
# Generate PAPI descriptors from a running node
# Parameters:
#   ws_url - WebSocket URL of the node (default: ws://127.0.0.1:10000)
papi-generate ws_url="ws://127.0.0.1:10000": npm-install
    #!/usr/bin/env bash
    set -e
    echo "🔧 Generating PAPI descriptors from {{ ws_url }}..."
    npx papi add -w "{{ ws_url }}" bulletin

# Setup all services for IPFS
# Parameters:
#   runtime - Runtime to build and run (e.g., "bulletin-polkadot-runtime", "bulletin-westend-runtime")
#   ipfs_mode - IPFS backend: "kubo-docker" (default) or "kubo-native" (local, no Docker required)
setup-services test_dir runtime ipfs_mode="kubo-docker": npm-install
    #!/usr/bin/env bash
    set -e

    if [ "{{ runtime }}" = "bulletin-westend-runtime" ]; then
        just bulletin-westend-parachain-zombienet-start "{{ test_dir }}" "{{ runtime }}"
    elif [ "{{ runtime }}" = "bulletin-polkadot-parachain-runtime" ]; then
        just bulletin-polkadot-parachain-zombienet-start "{{ test_dir }}" "{{ runtime }}"
    elif [ "{{ runtime }}" = "bulletin-polkadot-runtime" ]; then
        just bulletin-solo-zombienet-start "{{ test_dir }}" "{{ runtime }}"
    else
        echo "❌ Unhandled runtime: {{ runtime }} specified!"
        exit 1
    fi

    # Generate PAPI descriptors from running node.
    just papi-generate

    # Start IPFS (Peering.Peers is configured inside the start recipes before daemon launch/restart)
    if [ "{{ ipfs_mode }}" = "kubo-native" ]; then
        echo "🔧 Setting up services with Kubo IPFS (runtime: {{ runtime }})..."
        just ipfs-kubo-shutdown "{{ test_dir }}"
        just ipfs-kubo-start "{{ test_dir }}" "{{ runtime }}"
        echo "✅ Services setup complete (kubo-native mode)"
    elif [ "{{ ipfs_mode }}" = "kubo-docker" ]; then
        echo "🔧 Tearing down Docker services if they are running..."
        just ipfs-shutdown "{{ test_dir }}"
        echo "🐳 Setting up services with Docker IPFS (runtime: {{ runtime }})..."
        just ipfs-start "{{ test_dir }}" "{{ runtime }}"
        echo "✅ Services setup complete (kubo-docker mode)"
    else
        echo "❌ Invalid ipfs_mode: '{{ ipfs_mode }}'. Must be 'kubo-docker' or 'kubo-native'."
        exit 1
    fi

# Stop all services
# Parameters:
#   ipfs_mode - IPFS backend: "kubo-docker" (default) or "kubo-native" (local)
teardown-services test_dir ipfs_mode="kubo-docker":
    #!/usr/bin/env bash

    # Stop all background processes
    just kill-pids "{{ test_dir }}"

    if [ "{{ ipfs_mode }}" = "kubo-native" ]; then
        echo "🧹 Stopping Kubo IPFS daemon..."
        just ipfs-kubo-shutdown "{{ test_dir }}"
        echo "✅ Kubo services stopped"
    elif [ "{{ ipfs_mode }}" = "kubo-docker" ]; then
        echo "🧹 Stopping all Docker services..."
        just ipfs-shutdown "{{ test_dir }}"
        echo "✅ Docker services stopped"
    else
        echo "❌ Invalid ipfs_mode: '{{ ipfs_mode }}'. Must be 'kubo-docker' or 'kubo-native'."
        exit 1
    fi

# Start all services for a runtime (use with run-test-* recipes)
# Usage: just start-services /tmp/my-test-dir bulletin-polkadot-runtime
# Usage: just start-services /tmp/my-test-dir bulletin-polkadot-runtime kubo-native
start-services test_dir runtime ipfs_mode="kubo-docker":
    #!/usr/bin/env bash
