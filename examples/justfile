# Setup prerequisites for parachain runtime (polkadot and polkadot-omni-node binaries)
# This recipe clones polkadot-sdk, builds required binaries, and copies them to ~/local_bulletin_testing/bin
setup-parachain-prerequisites:
    #!/usr/bin/env bash
    set -e
    if [ -n "$SKIP_PARACHAIN_SETUP" ]; then
        echo "⏭️  Skipping parachain prerequisites (SKIP_PARACHAIN_SETUP set)"
    else
        ROOT_DIR="{{ justfile_directory() }}/.."
        cd "$ROOT_DIR"
        ./scripts/setup_parachain_prerequisites.sh
        cd -
    fi

compute-test-dir:
    #!/usr/bin/env bash
    if [ -n "$TEST_DIR" ]; then
        echo "$TEST_DIR";
    else
        TEST_DIR="$(mktemp -d /tmp/bulletin-tests-run-XXXXX)/test";
        mkdir -p "$TEST_DIR";
        echo "$TEST_DIR";
    fi

# Install JavaScript dependencies
npm-install:
    npm install

kill-pids test_dir:
    #!/usr/bin/env bash
    set -e

    # Kill any existing background processes using stored PIDs
    echo "🔍 Checking for existing background processes - PIDs stored in {{ test_dir }}..."
    for pidfile in {{ test_dir }}/*.pid; do
        if [ -f "$pidfile" ]; then
            PID=$(cat "$pidfile")
            SERVICE=$(basename "$pidfile" .pid)
            if kill -0 $PID 2>/dev/null; then
                echo "   Found existing $SERVICE process (PID: $PID), pidfile: $pidfile"
                # Kill the process and its children
                pkill -TERM -P $PID 2>/dev/null || true
                sleep 2
                pkill -9 -P $PID 2>/dev/null || true
                sleep 2
                kill -9 $PID 2>/dev/null || true
                echo "   ✓ Cleaned up $SERVICE process"
            else
                echo "   Stale $SERVICE PID file: $pidfile found (process not running)"
            fi
            rm "$pidfile"
        fi
    done

# Resolve the zombienet binary path. Prints the absolute path to stdout.
# Checks ZOMBIENET_BINARY env var first, then falls back to ../zombienet-*-*.
_resolve-zombienet-bin:
    #!/usr/bin/env bash
    set -e
    if [ -n "$ZOMBIENET_BINARY" ]; then
        if command -v "$ZOMBIENET_BINARY" >/dev/null 2>&1; then
            ZOMBIENET_BIN="$(command -v "$ZOMBIENET_BINARY")"
        else
            ZOMBIENET_BIN="$ZOMBIENET_BINARY"
        fi
    else
        ZOMBIENET_BIN=$(ls ../zombienet-*-* 2>/dev/null | head -n 1)
        if [ -z "$ZOMBIENET_BIN" ]; then
            echo "❌ Error: Zombienet binary not found" >&2
            echo "   Set ZOMBIENET_BINARY environment variable or ensure zombienet-* exists in parent directory" >&2
            exit 1
        fi
    fi
    ZOMBIENET_BIN="$(realpath "$ZOMBIENET_BIN")"
    if [ ! -x "$ZOMBIENET_BIN" ]; then
        echo "❌ Error: Zombienet binary not executable: $ZOMBIENET_BIN" >&2
        exit 1
    fi
    echo "$ZOMBIENET_BIN"

# Wait for an RPC endpoint to accept connections, checking that the background process stays alive.
# Parameters:
#   pid - PID of the background process to monitor
#   log_file - Log file to tail on failure
#   port - TCP port to check (default: 10000)
#   timeout - Seconds to wait (default: 30)
_wait-for-rpc pid log_file port="10000" timeout="30":
    #!/usr/bin/env bash
    set -e
    echo "   Waiting for RPC on 127.0.0.1:{{ port }}..."
    for i in $(seq 1 {{ timeout }}); do
        if ! kill -0 {{ pid }} 2>/dev/null; then
            echo "   ❌ Process (PID {{ pid }}) died during startup. Logs:"
            tail -20 "{{ log_file }}"
            exit 1
        fi
        if (echo > /dev/tcp/127.0.0.1/{{ port }}) 2>/dev/null; then
            echo "   ✅ RPC is reachable (after ${i}s)"
            exit 0
        fi
        if [ "$i" -eq {{ timeout }} ]; then
            echo "   ❌ RPC not reachable after {{ timeout }} seconds"
            echo "   Debug: ss -tlnp | grep {{ port }}:"
            ss -tlnp 2>/dev/null | grep {{ port }} || netstat -tlnp 2>/dev/null | grep {{ port }} || true
            tail -20 "{{ log_file }}"
            exit 1
        fi
        sleep 1
    done

# Start solo chain or parachain with zombienet in background
# Parameters:
#   runtime - Runtime name (e.g., "bulletin-polkadot-runtime"), taken from ../scripts/runtimes-matrix.json
bulletin-solo-zombienet-start test_dir runtime="bulletin-polkadot-runtime":
    #!/usr/bin/env bash
    set -e

    ZOMBIENET_BIN="$(just _resolve-zombienet-bin)"

    echo "   Setting up Polkadot runtime..."
    ROOT_DIR="{{ justfile_directory() }}/.."
    # Build the node binary (which will build the runtime as a dependency)
    cargo build --release -p polkadot-bulletin-chain
    POLKADOT_BULLETIN_BINARY_PATH="$ROOT_DIR/target/release/polkadot-bulletin-chain"

    cat <<EOF
    ⚡ Starting Bulletin chain with zombienet
        runtime   : {{ runtime }}
        test_dir  : {{ test_dir }}
        zombienet : $ZOMBIENET_BIN
        POLKADOT_BULLETIN_BINARY_PATH : $POLKADOT_BULLETIN_BINARY_PATH
    EOF
    (yes y | POLKADOT_BULLETIN_BINARY_PATH="$POLKADOT_BULLETIN_BINARY_PATH" \
        $ZOMBIENET_BIN -p native spawn --dir {{ test_dir }} "$ROOT_DIR/zombienet/bulletin-polkadot-local.toml" > {{ test_dir }}/zombienet.log 2>&1) &

    ZOMBIENET_PID=$!
    echo $ZOMBIENET_PID > {{ test_dir }}/zombienet.pid
    echo "   Zombienet PID: $ZOMBIENET_PID"
    echo "   Log: {{ test_dir }}/zombienet.log"
    just _wait-for-rpc $ZOMBIENET_PID "{{ test_dir }}/zombienet.log"

# Start polkadot parachain with zombienet in background
# Parameters:
#   runtime - Runtime name (e.g., "bulletin-polkadot-parachain-runtime"), taken from ../scripts/runtimes-matrix.json
bulletin-polkadot-parachain-zombienet-start test_dir runtime="bulletin-polkadot-parachain-runtime":
    #!/usr/bin/env bash
    set -e

    # Find zombienet binary (use env var if set, otherwise search)
    if [ -n "$ZOMBIENET_BINARY" ]; then
        ZOMBIENET_BIN="$ZOMBIENET_BINARY"
    else
        ZOMBIENET_BIN=$(ls ../zombienet-*-* 2>/dev/null | head -n 1)
    fi

    if ! command -v "$ZOMBIENET_BIN" >/dev/null 2>&1; then
        echo "❌ Error: Zombienet binary not found"
        echo "   Tried: $ZOMBIENET_BIN"
        echo "   Set ZOMBIENET_BINARY environment variable or ensure zombienet-* exists in parent directory"
        exit 1
    fi

    # Run prerequisites setup first
    just setup-parachain-prerequisites

    # Set paths to binaries
    if [ -n "$SKIP_PARACHAIN_SETUP" ]; then
        # Expect in the PATH
        POLKADOT_BINARY_PATH=polkadot
        POLKADOT_PARACHAIN_BINARY_PATH=polkadot-omni-node
    else
        POLKADOT_BINARY_PATH=~/local_bulletin_testing/bin/polkadot
        POLKADOT_PARACHAIN_BINARY_PATH=~/local_bulletin_testing/bin/polkadot-omni-node
    fi

    # Verify binaries exist after setup
    if ! command -v "$POLKADOT_BINARY_PATH"; then
        echo "❌ Error: Prerequisites setup completed but binaries still not found"
        echo "   Expected POLKADOT_BINARY_PATH: $POLKADOT_BINARY_PATH"
        exit 1
    fi
    if ! command -v "$POLKADOT_PARACHAIN_BINARY_PATH"; then
        echo "❌ Error: Prerequisites setup completed but binaries still not found"
        echo "   Expected POLKADOT_PARACHAIN_BINARY_PATH: $POLKADOT_PARACHAIN_BINARY_PATH"
        exit 1
    fi

    # Generate chain specs (the relay runtime WASM is checked into
    # examples/production-runtimes/, so no build step needed)
    ROOT_DIR="{{ justfile_directory() }}/.."
    cd "$ROOT_DIR"

    echo "   Creating Polkadot relay chain spec..."
    PATH="$HOME/local_bulletin_testing/bin:$PATH" ./scripts/create_polkadot_relay_spec.sh

    echo "   Creating Polkadot parachain chain spec..."
    PATH="$HOME/local_bulletin_testing/bin:$PATH" ./scripts/create_bulletin_polkadot_parachain_spec.sh
    cd -

    # Run zombienet from root directory so relative paths in config work correctly
    cat <<EOF
    ⚡ Starting Bulletin chain with zombienet
        runtime   : {{ runtime }}
        test_dir  : {{ test_dir }}
        zombienet : $ZOMBIENET_BIN
        POLKADOT_BINARY_PATH : $POLKADOT_BINARY_PATH
        POLKADOT_PARACHAIN_BINARY_PATH : $POLKADOT_PARACHAIN_BINARY_PATH
    EOF
    cd "$ROOT_DIR"
    (yes y | POLKADOT_BINARY_PATH=$POLKADOT_BINARY_PATH \
        POLKADOT_PARACHAIN_BINARY_PATH=$POLKADOT_PARACHAIN_BINARY_PATH \
        $ZOMBIENET_BIN -p native spawn --dir {{ test_dir }} "$ROOT_DIR/zombienet/bulletin-polkadot-parachain-local.toml" > {{ test_dir }}/zombienet.log 2>&1) &
    cd -

    ZOMBIENET_PID=$!
    echo $ZOMBIENET_PID > {{ test_dir }}/zombienet.pid
    echo "   Zombienet PID: $ZOMBIENET_PID"
    echo "   Log: {{ test_dir }}/zombienet.log"
    # TODO: replace with better check for produced/finalized block 1 with timeout 180s
    echo "   Waiting for chain to start (180 seconds)..."
    sleep 180

# Start westend parachain with zombienet in background
# Parameters:
#   runtime - Runtime name (e.g., "bulletin-westend-runtime"), taken from ../scripts/runtimes-matrix.json
bulletin-westend-parachain-zombienet-start test_dir runtime="bulletin-westend-runtime":
    #!/usr/bin/env bash
    set -e

    ZOMBIENET_BIN="$(just _resolve-zombienet-bin)"

    # Run prerequisites setup first
    just setup-parachain-prerequisites

    # Set paths to binaries
    if [ -n "$SKIP_PARACHAIN_SETUP" ]; then
        # Expect in the PATH
        POLKADOT_BINARY_PATH=polkadot
        POLKADOT_PARACHAIN_BINARY_PATH=polkadot-omni-node
    else
        POLKADOT_BINARY_PATH=~/local_bulletin_testing/bin/polkadot
        POLKADOT_PARACHAIN_BINARY_PATH=~/local_bulletin_testing/bin/polkadot-omni-node
    fi

    # Verify binaries exist after setup
    if ! command -v "$POLKADOT_BINARY_PATH"; then
        echo "❌ Error: Prerequisites setup completed but binaries still not found"
        echo "   Expected POLKADOT_BINARY_PATH: $POLKADOT_BINARY_PATH"
        exit 1
    fi
    if ! command -v "$POLKADOT_PARACHAIN_BINARY_PATH"; then
        echo "❌ Error: Prerequisites setup completed but binaries still not found"
        echo "   Expected POLKADOT_PARACHAIN_BINARY_PATH: $POLKADOT_PARACHAIN_BINARY_PATH"
        exit 1
    fi

    # Create chain spec
    echo "   Creating Westend chain spec..."
    ROOT_DIR="{{ justfile_directory() }}/.."
    PATH="$HOME/local_bulletin_testing/bin:$PATH" "$ROOT_DIR/scripts/create_bulletin_westend_spec.sh"

    cat <<EOF
    ⚡ Starting Bulletin chain with zombienet
        runtime   : {{ runtime }}
        test_dir  : {{ test_dir }}
        zombienet : $ZOMBIENET_BIN
        POLKADOT_BINARY_PATH : $POLKADOT_BINARY_PATH
        POLKADOT_PARACHAIN_BINARY_PATH : $POLKADOT_PARACHAIN_BINARY_PATH
    EOF
    # Zombienet resolves chain_spec_path relative to CWD, so run from repo root
    (cd "$ROOT_DIR" && yes y | POLKADOT_BINARY_PATH=$POLKADOT_BINARY_PATH \
        POLKADOT_PARACHAIN_BINARY_PATH=$POLKADOT_PARACHAIN_BINARY_PATH \
        $ZOMBIENET_BIN -p native spawn --dir {{ test_dir }} "$ROOT_DIR/zombienet/bulletin-westend-local.toml" > {{ test_dir }}/zombienet.log 2>&1) &

    ZOMBIENET_PID=$!
    echo $ZOMBIENET_PID > {{ test_dir }}/zombienet.pid
    echo "   Zombienet PID: $ZOMBIENET_PID"
    echo "   Log: {{ test_dir }}/zombienet.log"
    just _wait-for-rpc $ZOMBIENET_PID "{{ test_dir }}/zombienet.log"

# Check if Docker is available and running
_check-docker:
    #!/usr/bin/env bash
    if ! command -v docker &> /dev/null; then
        echo "❌ Error: Docker is not installed."
        echo "   Please install Docker Desktop from: https://www.docker.com/products/docker-desktop"
        exit 1
    fi

    if ! docker ps &> /dev/null; then
        echo "❌ Error: Docker is not running."
        echo "   Please start Docker Desktop and try again."
        echo "   On macOS: Open Docker Desktop from Applications"
        exit 1
    fi

