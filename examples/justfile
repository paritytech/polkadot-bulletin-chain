# ============================================================================
# Live network tests (external endpoints - Westend, Paseo, etc.)
# ============================================================================
#
# Runs the four canonical end-to-end scripts against a live Bulletin
# deployment: store_big_data.js (IPFS + multi-chunked files),
# authorize_and_store_papi_smoldot.js (Smoldot light client),
# hop_round_trip.js (HOP), and check_chopsticks.js (Chopsticks fork).
#
# The seed must hold authorizer rights on the target network — the scripts
# authorize their worker signers inline (no pre-provisioned accounts needed).
#
# Per-network usage:
#   just run-live-tests-westend         <seed>
#   just run-live-tests-paseo           <seed>
#   just run-live-tests-paseo-next-v2   <seed>
#   just run-live-tests-previewnet      <seed>
#   just run-live-tests-summit          <seed>   # needs `just ipfs-kubo-summit` running
#
# Ad-hoc usage (any network, supply all endpoints):
#   just run-live-tests <seed> <rpc_url> <collator_url> <ipfs_gateway> <relay_chainspec> <parachain_chainspec>

# Live RPC endpoints (mirrors scripts/runtimes-matrix.json `try_runtime.instances[].uris`)
WESTEND_RPC         := "wss://westend-bulletin-rpc.polkadot.io"
PASEO_RPC           := "wss://paseo-bulletin-rpc.polkadot.io"
PASEO_NEXT_V2_RPC   := "wss://paseo-bulletin-next-rpc.polkadot.io"
PREVIEWNET_RPC      := "wss://previewnet.substrate.dev/bulletin"

# HOP collator RPC endpoints (NOT the same as the public RPC node — HOP RPC methods
# live on the collator's local interface). TODO(#580): fill in once published.
