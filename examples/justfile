# Builds the Westend runtime WASM by default so auto-renewal code is included.
# Parameters:
#   endpoint - WebSocket URL of the Bulletin chain (default: wss://westend-bulletin-rpc.polkadot.io)
#   wasm_path - Path to runtime WASM override (default: auto-built from source)
#   skip_build - Set to "true" to skip WASM build (default: false)
run-test-auto-renew-chopsticks endpoint="wss://westend-bulletin-rpc.polkadot.io" wasm_path="" skip_build="false": npm-install
    #!/usr/bin/env bash
    set -e
    ROOT_DIR="{{ justfile_directory() }}/.."
    WASM_PATH="{{ wasm_path }}"

    if [ -z "$WASM_PATH" ]; then
        WASM_PATH="$ROOT_DIR/target/release/wbuild/bulletin-westend-runtime/bulletin_westend_runtime.compact.compressed.wasm"
    fi

    if [ "{{ skip_build }}" != "true" ]; then
        echo "🔧 Building Westend runtime WASM..."
        cargo build --release -p bulletin-westend-runtime
        echo "✅ WASM built: $WASM_PATH"
    fi

    node check_auto_renew_chopsticks.js "{{ endpoint }}" "$WASM_PATH"

