# Fetch Summit relay + bulletin parachain raw chainspecs (cached, gitignored).
_fetch-summit-chainspecs:
    #!/usr/bin/env bash
    set -e
    dir="{{ SUMMIT_SPEC_DIR }}"
    base="https://raw.githubusercontent.com/paritytech/chainspecs/{{ SUMMIT_CHAINSPECS_REF }}/summit"
    mkdir -p "$dir"
    [ -s "$dir/relay.raw.json" ]    || curl -fsSL "$base/relaychain/raw.json"        -o "$dir/relay.raw.json"
    [ -s "$dir/bulletin.raw.json" ] || curl -fsSL "$base/parachain/bulletin/raw.json" -o "$dir/bulletin.raw.json"
    echo "✅ Summit chainspecs in $dir"

# Start a local Kubo IPFS node peered to the Summit bulletin collators over Bitswap.
# Run in a separate shell before the IPFS-dependent Summit tests; the gateway serves
# on {{ IPFS_GATEWAY_PORT }} (matches SUMMIT_IPFS_GATEWAY). Blocks until interrupted.
ipfs-kubo-summit: ipfs-kubo-install
    #!/usr/bin/env bash
    set -e
    IPFS="{{ KUBO_DIR }}/ipfs"
    export IPFS_PATH="${IPFS_PATH:-/tmp/summit-ipfs}"
    rm -rf "$IPFS_PATH"; mkdir -p "$IPFS_PATH"
    $IPFS init >/dev/null
    $IPFS config Addresses.Gateway "/ip4/127.0.0.1/tcp/{{ IPFS_GATEWAY_PORT }}"
    $IPFS config Addresses.API "/ip4/127.0.0.1/tcp/{{ IPFS_API_PORT }}"
    $IPFS config --json Addresses.Swarm '["/ip4/0.0.0.0/tcp/{{ IPFS_SWARM_PORT }}","/ip4/0.0.0.0/tcp/4012/ws"]'
    $IPFS config --json Routing.Type '"none"'
    $IPFS config --json Discovery.MDNS.Enabled false
    $IPFS bootstrap rm --all >/dev/null
    # Collator p2p identities from the Web3 Summit Network doc.
    $IPFS config --json Peering.Peers '[
      {"ID":"12D3KooWC6q8q3NXscVcpxMbteYrmzjpy7NvYnD4QDRkAQJ9ng8r","Addrs":["/dns4/summit-bulletin-collator-node-0.parity-chains.parity.io/tcp/443/wss"]},
      {"ID":"12D3KooWRiRRk8EzmENBD6SkP7v2riWa6s74X7wzhnx84SxfD4yr","Addrs":["/dns4/summit-bulletin-collator-node-1.parity-chains.parity.io/tcp/443/wss"]}
    ]'
    echo "🛰️  Kubo peered to Summit collators; gateway http://127.0.0.1:{{ IPFS_GATEWAY_PORT }}"
    exec $IPFS daemon

# Run live tests against Web3 Summit Bulletin.
# Prereq: `just ipfs-kubo-summit` running in another shell (provides the IPFS gateway).
# HOP fails until summit-hop-0/1 DNS is published; the other three pass with //Eve.
run-live-tests-summit seed image_size="small": _fetch-summit-chainspecs
    just _run-live-tests "{{ SUMMIT_RPC }}" "{{ SUMMIT_HOP_POOL_WS }}" "{{ SUMMIT_IPFS_GATEWAY }}" "{{ SUMMIT_RELAY_SPEC }}" "{{ SUMMIT_PARACHAIN_SPEC }}" "{{ seed }}" "{{ image_size }}"

